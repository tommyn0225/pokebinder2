{
  "openapi": "3.0.3",
  "info": {
    "title": "Binder Public API",
    "version": "1.2.0",
    "description": "Read-only access to Binder's own value-added layer: public binders (holdings and valuation), a binder's price history, public trade lists, and Binder's normalized card catalog.\n\nThe catalog covers every card tracked in Binder, in our normalized cross-game model, with a per-card price history built from our own daily snapshots. It is enough to build a collection app of your own on top of. This API deliberately does not expose a live upstream card or price search passthrough. Card data and pricing come from Scryfall (MTG), PokéWallet (Pokémon), and OPTCG API (One Piece); every response includes an `attribution` field crediting them.\n\nNo authentication is required. Only resources their owner has explicitly made public are reachable; everything else returns 404.\n\n**Errors** use one envelope: `{ \"error\": { \"code\": \"...\", \"message\": \"...\" } }`, where `code` is a stable machine-readable string.\n\n**Caching**: every GET returns a weak `ETag`; send it back as `If-None-Match` to get a `304 Not Modified` when the payload is unchanged.\n\n**Pagination**: `/api/v1/cards` is cursor-paginated — follow `next_cursor` until `has_more` is false.\n\n**Rate limiting**: requests are limited per IP (60 requests/minute). Over the limit returns `429` with a `Retry-After` header and error code `rate_limited`.",
    "contact": {
      "name": "Binder"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "tags": [
    { "name": "Binders", "description": "Public binders and their price history" },
    { "name": "Trades", "description": "Public trade lists" },
    { "name": "Cards", "description": "Binder's normalized card catalog and per-card price history" },
    { "name": "Meta", "description": "API metadata" }
  ],
  "paths": {
    "/api/v1/binders/{id}": {
      "get": {
        "tags": ["Binders"],
        "summary": "Get a public binder",
        "description": "Returns a public binder's metadata, its holdings, and current total USD value. Returns 404 if the binder does not exist or is not public.",
        "operationId": "getPublicBinder",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Binder UUID.",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "The public binder.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BinderResponse" }
              }
            }
          },
          "404": {
            "description": "Binder not found or not public.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/binders/{id}/history": {
      "get": {
        "tags": ["Binders"],
        "summary": "Get a public binder's value history",
        "description": "Returns Binder's own daily price history for a public binder, built from our snapshots (not upstream history). Returns 404 if the binder does not exist or is not public.",
        "operationId": "getPublicBinderHistory",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Binder UUID.",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily value history.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HistoryResponse" }
              }
            }
          },
          "404": {
            "description": "Binder not found or not public.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/trades/{token}": {
      "get": {
        "tags": ["Trades"],
        "summary": "Get a public trade list",
        "description": "Returns the cards a user has marked for trade, addressed by the trade list's share token. Returns 404 if the token is unknown or the trade list is not public.",
        "operationId": "getPublicTradeList",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "description": "Trade list share token (UUID).",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "The public trade list.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TradesResponse" }
              }
            }
          },
          "404": {
            "description": "Trade list not found or not public.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/cards": {
      "get": {
        "tags": ["Cards"],
        "summary": "Search the card catalog",
        "description": "Searches Binder's normalized card catalog — every distinct card tracked in Binder, across all three games. Served from Binder's own data, not a live upstream search, so a card appears here once someone tracks it.",
        "operationId": "searchCards",
        "parameters": [
          {
            "name": "game",
            "in": "query",
            "required": false,
            "description": "Restrict results to one game.",
            "schema": { "$ref": "#/components/schemas/Game" }
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Case-insensitive substring match on the card name.",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of cards to return in this page (1–100).",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "description": "Opaque pagination cursor. Pass the `next_cursor` from the previous page to fetch the next one; omit for the first page.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "One page of matching catalog cards, ordered by name. Follow `next_cursor` while `has_more` is true.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CardsResponse" }
              }
            }
          },
          "400": {
            "description": "Unknown game or invalid cursor.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (60 requests/minute per IP).",
            "headers": {
              "Retry-After": {
                "description": "Seconds to wait before retrying.",
                "schema": { "type": "integer" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/cards/{game}/{id}": {
      "get": {
        "tags": ["Cards"],
        "summary": "Get a catalog card with price history",
        "description": "Returns one card from the catalog in Binder's normalized model, with Binder's own daily USD price history for it (built from our snapshots, not upstream history). Returns 404 if no Binder user tracks the card.",
        "operationId": "getCard",
        "parameters": [
          {
            "name": "game",
            "in": "path",
            "required": true,
            "schema": { "$ref": "#/components/schemas/Game" }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The card's upstream id (Scryfall UUID, PokéWallet card id, or OPTCG card id).",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "The card and its price history.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CardResponse" }
              }
            }
          },
          "404": {
            "description": "Card not found in catalog.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/cards/{game}/{id}/history": {
      "get": {
        "tags": ["Cards"],
        "summary": "Get a catalog card's price history",
        "description": "Returns Binder's own daily USD price history for one catalog card, built from our snapshots (not upstream history), one point per day. Use `days` to bound the window. Returns 404 if no Binder user tracks the card.",
        "operationId": "getCardHistory",
        "parameters": [
          {
            "name": "game",
            "in": "path",
            "required": true,
            "schema": { "$ref": "#/components/schemas/Game" }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The card's upstream id (Scryfall UUID, PokéWallet card id, or OPTCG card id).",
            "schema": { "type": "string" }
          },
          {
            "name": "days",
            "in": "query",
            "required": false,
            "description": "Size of the history window in days (1–365).",
            "schema": { "type": "integer", "minimum": 1, "maximum": 365, "default": 30 }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily price history for the card.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CardHistoryResponse" }
              }
            }
          },
          "404": {
            "description": "Card not found in catalog.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/openapi.json": {
      "get": {
        "tags": ["Meta"],
        "summary": "Get this OpenAPI document",
        "operationId": "getOpenApi",
        "responses": {
          "200": {
            "description": "The OpenAPI 3.0 specification for this API.",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Game": {
        "type": "string",
        "enum": ["mtg", "pokemon", "onepiece"],
        "description": "The trading card game a binder or card belongs to."
      },
      "Price": {
        "type": "object",
        "description": "Current prices. Any field may be null when unavailable upstream.",
        "properties": {
          "usd": { "type": "number", "nullable": true },
          "usd_foil": { "type": "number", "nullable": true },
          "eur": { "type": "number", "nullable": true }
        }
      },
      "Card": {
        "type": "object",
        "properties": {
          "card_id": { "type": "string" },
          "name": { "type": "string" },
          "game": { "$ref": "#/components/schemas/Game" },
          "set_name": { "type": "string" },
          "set_code": { "type": "string" },
          "collector_number": { "type": "string" },
          "rarity": { "type": "string", "nullable": true },
          "image_url": { "type": "string", "nullable": true },
          "quantity": { "type": "integer", "minimum": 1 },
          "finish": {
            "type": "string",
            "enum": ["nonfoil", "foil"],
            "description": "Which printing this holding is; foil values against price.usd_foil."
          },
          "for_trade": { "type": "boolean", "description": "Present on binder responses; whether this holding is marked for trade." },
          "price": { "$ref": "#/components/schemas/Price" }
        },
        "required": ["card_id", "name", "game", "set_name", "quantity", "finish", "price"]
      },
      "BinderResponse": {
        "type": "object",
        "properties": {
          "binder": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "name": { "type": "string" },
              "game": { "$ref": "#/components/schemas/Game" }
            },
            "required": ["id", "name", "game"]
          },
          "card_count": { "type": "integer", "description": "Sum of holding quantities." },
          "total_usd": { "type": "number", "description": "Current total USD value of the binder." },
          "holdings": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Card" }
          },
          "attribution": { "type": "string" }
        },
        "required": ["binder", "card_count", "total_usd", "holdings", "attribution"]
      },
      "CatalogCard": {
        "type": "object",
        "description": "A card in Binder's normalized cross-game model, without holding context (no quantities — the catalog never exposes who holds a card or how many).",
        "properties": {
          "card_id": { "type": "string" },
          "name": { "type": "string" },
          "game": { "$ref": "#/components/schemas/Game" },
          "set_name": { "type": "string" },
          "set_code": { "type": "string" },
          "collector_number": { "type": "string" },
          "rarity": { "type": "string", "nullable": true },
          "image_url": { "type": "string", "nullable": true },
          "price": { "$ref": "#/components/schemas/Price" }
        },
        "required": ["card_id", "name", "game", "set_name", "price"]
      },
      "CardsResponse": {
        "type": "object",
        "properties": {
          "count": { "type": "integer", "description": "Number of cards in THIS page (not the catalog total)." },
          "has_more": { "type": "boolean", "description": "Whether another page exists." },
          "next_cursor": {
            "type": "string",
            "nullable": true,
            "description": "Cursor for the next page, or null when has_more is false."
          },
          "cards": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CatalogCard" }
          },
          "attribution": { "type": "string" }
        },
        "required": ["count", "has_more", "next_cursor", "cards", "attribution"]
      },
      "PricePoint": {
        "type": "object",
        "properties": {
          "day": { "type": "string", "format": "date", "example": "2026-07-01" },
          "price_usd": { "type": "number" }
        },
        "required": ["day", "price_usd"]
      },
      "CardResponse": {
        "type": "object",
        "properties": {
          "card": { "$ref": "#/components/schemas/CatalogCard" },
          "history": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PricePoint" }
          },
          "attribution": { "type": "string" }
        },
        "required": ["card", "history", "attribution"]
      },
      "CardHistoryResponse": {
        "type": "object",
        "properties": {
          "game": { "$ref": "#/components/schemas/Game" },
          "card_id": { "type": "string" },
          "days": { "type": "integer", "description": "The requested window size in days." },
          "history": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PricePoint" }
          },
          "attribution": { "type": "string" }
        },
        "required": ["game", "card_id", "days", "history", "attribution"]
      },
      "HistoryPoint": {
        "type": "object",
        "properties": {
          "day": { "type": "string", "format": "date-time" },
          "total_usd": { "type": "number" }
        },
        "required": ["day", "total_usd"]
      },
      "HistoryResponse": {
        "type": "object",
        "properties": {
          "binder_id": { "type": "string", "format": "uuid" },
          "history": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/HistoryPoint" }
          },
          "attribution": { "type": "string" }
        },
        "required": ["binder_id", "history", "attribution"]
      },
      "TradesResponse": {
        "type": "object",
        "properties": {
          "total_cards": { "type": "integer" },
          "cards": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Card" }
          },
          "attribution": { "type": "string" }
        },
        "required": ["total_cards", "cards", "attribution"]
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "enum": ["invalid_request", "not_found", "rate_limited", "internal"],
                "description": "Stable machine-readable error code."
              },
              "message": { "type": "string", "description": "Human-readable detail; may change." }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      }
    }
  }
}
